# Kestra control plane on Ubuntu
KESTRA_HTTP_PORT=18080
KESTRA_POSTGRES_DB=kestra
KESTRA_POSTGRES_USER=kestra
KESTRA_POSTGRES_PASSWORD=kestra
KESTRA_POSTGRES_PORT=55433
KESTRA_BASIC_AUTH_USERNAME=admin@kestra.io
KESTRA_BASIC_AUTH_PASSWORD=Kestra20260327!

# Canonical runtime inputs for the hybrid topology:
# - host.docker.internal:18100 -> Windows app :38001
# - host.docker.internal:18192 -> Windows writeback A :8092
# - host.docker.internal:18193 -> Windows mesh_runner :8093
# - host.docker.internal:18194 -> Windows promote_prep :8094
# - host.docker.internal:18195 -> Windows writeback B :8095
APP_BASE_URL=http://host.docker.internal:18100
NEW_API_BASE_URL=http://192.168.232.141:3000
NEW_API_ADMIN_USERNAME=naadmin
NEW_API_ADMIN_PASSWORD=replace-me
NEW_API_SOURCE_PROBE_MAX_WORKERS=4
NEW_API_CANDIDATE_PROBE_MAX_WORKERS=4
NEW_API_GOVERNANCE_LEASE_TTL_SECONDS=1800
NEW_API_RELAY_PROVISION_RETRIES=1
NEW_API_RELAY_GOVERN_RETRIES=2
NEW_API_RELAY_RETRY_DELAY_SECONDS=5
WRITEBACK_A_BASE_URL=http://host.docker.internal:18192
MESH_RUNNER_BASE_URL=http://host.docker.internal:18193
PROMOTE_PREP_BASE_URL=http://host.docker.internal:18194
WRITEBACK_B_BASE_URL=http://host.docker.internal:18195
LOOP_CONTROLLER_BASE_URL=http://host.docker.internal:18196
PROMOTE_PREP_REDIS_URL=redis://127.0.0.1:6379/0
ISSUE_MESH_READONLY_MAX_WORKERS=12
ISSUE_MESH_MAX_WORKERS_CAP=12
CODEX_AUDIT_GATEWAY_ONLY=false
CODEX_CANONICAL_PROVIDER=newapi-192.168.232.141-3000-stable
CODEX_READONLY_LANE=codex-readonly
CODEX_STABLE_LANE=codex-stable
# Readonly lane isolation: MUST be explicit when CODEX_READONLY_LANE is enabled.
# Use ro-a..ro-d provider identities to avoid a single failure domain.
CODEX_READONLY_PROVIDER_ALLOWLIST=newapi-192.168.232.141-3000-ro-a,newapi-192.168.232.141-3000-ro-b,newapi-192.168.232.141-3000-ro-c,newapi-192.168.232.141-3000-ro-d

# Loop Controller settings
FIX_GOAL_CONSECUTIVE=10
AUDIT_INTERVAL_SECONDS=300
MONITOR_INTERVAL_SECONDS=1800
AUTONOMY_LOOP_ENABLED=true
AUTONOMY_LOOP_MODE=fix
AUTONOMY_LOOP_FIX_GOAL=10
AUTONOMY_LOOP_AUDIT_INTERVAL_SECONDS=300
AUTONOMY_LOOP_MONITOR_INTERVAL_SECONDS=1800
INTERNAL_TOKEN_ALIASES=

# Runtime secrets (set before production use)
INTERNAL_TOKEN=replace-me
NEW_API_TOKEN=replace-me
WRITEBACK_A_TOKEN=replace-me
WRITEBACK_B_TOKEN=replace-me
MESH_RUNNER_TOKEN=replace-me
PROMOTE_PREP_TOKEN=replace-me
LOOP_CONTROLLER_TOKEN=replace-me
