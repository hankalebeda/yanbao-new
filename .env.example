APP_NAME="A-Share Research Platform"
API_PREFIX="/api/v1"

# =============================================================================
# 鏈湴 LLM锛圤llama锛?# 浣跨敤 Qwen3:8b 鏇夸唬鍘?deepseek-r1:8b锛屼腑鏂囬噾铻嶈兘鍔涙洿寮猴紝Q4閲忓寲绾?.2GB
# ollama pull qwen3:8b
# =============================================================================
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_MODEL_TEST="qwen3:8b"
OLLAMA_MODEL_PROD="qwen3:8b"
USE_TEST_MODEL=true
MOCK_LLM=false
REQUEST_TIMEOUT_SECONDS=60
MAX_LLM_RETRIES=2

# =============================================================================
# LLM 璺敱锛歐eb 鍚庣鏃ラ檺棰濓紙闃茶处鍙峰皝绂侊級
# 瓒呰繃闄愰鍚庡綋鏃ヨ嚜鍔ㄩ檷绾у埌涓嬩竴灞傦紝涓嶄腑鏂湇鍔?# =============================================================================
CHATGPT_WEB_DAILY_LIMIT=60
GEMINI_WEB_DAILY_LIMIT=60
DEEPSEEK_WEB_DAILY_LIMIT=60
QWEN_WEB_DAILY_LIMIT=60
WEB_CALL_MIN_INTERVAL_SEC=3

# LLM 璺敱锛欳LI 宸ュ叿鍛ㄩ檺棰濓紙淇濈暀棰濆害锛?# Gemini CLI / Codex CLI 宸插湪鏈満閰嶇疆濂斤紝鏃犻渶 API Key
GEMINI_CLI_WEEKLY_LIMIT=30
CODEX_CLI_WEEKLY_LIMIT=15

# LLM 璺敱锛歍ier-2 淇″彿寮哄害棰勫垽闂紙鍙湁 Top-N 鍗囩骇璋冪敤 Web锛?TIER2_SIGNAL_GATE_TOP_N=20

# LLM 璺敱锛氳皟璇曞紑鍏筹紙鐢熶骇鐜淇濇寔 false锛?LLM_FORCE_LOCAL=false
LLM_TIER1_SKIP_S4S5=false

# =============================================================================
# Storage
# =============================================================================
DATABASE_URL="sqlite:///./data/app.db"

# =============================================================================
# Scheduler
# =============================================================================
ENABLE_SCHEDULER=true
SCHEDULER_JOB_TIMEOUT_SECONDS=300
SCHEDULER_RETRY_COUNT=2
SCHEDULER_BACKOFF_BASE_SECONDS=2

# =============================================================================
# Stock pool锛堝垵鐗堢敤 env 閰嶇疆锛屽悗缁彲鎵╁睍涓哄悗鍙扮鐞嗭級
# =============================================================================
STOCK_POOL="600519.SH,000001.SZ,300750.SZ"

# 前端/平台配置：资金档位、股票别名、行业关键词（JSON 格式，见 .env 默认值）
CAPITAL_TIERS={"1w":{"label":"1 万档","amount":10000},"10w":{"label":"10 万档","amount":100000},"50w":{"label":"50 万档","amount":500000}}
STOCK_ALIASES={"600519":["贵州茅台","茅台","白酒","酱香"],"000001":["平安银行","银行","金融"],"300750":["宁德时代","动力电池","锂电"]}
STOCK_INDUSTRY_KEYWORDS={"600519":["白酒","消费","酱香","高端白酒"],"000001":["银行","信贷","金融"],"300750":["锂电","动力电池","新能源车"]}

# OAuth 第三方登录 (17 §2.1a)
OAUTH_CALLBACK_BASE=""
QQ_APP_ID=""
QQ_APP_KEY=""
WECHAT_APP_ID=""
WECHAT_APP_SECRET=""

# =============================================================================
# Data sources & reliability
# =============================================================================
MARKET_PROVIDER_ORDER="eastmoney,tdx"
STRICT_REAL_DATA=true
SOURCE_FAIL_OPEN_THRESHOLD=3
SOURCE_RECOVER_SUCCESS_THRESHOLD=2
SOURCE_CIRCUIT_COOLDOWN_SECONDS=300

# =============================================================================
# Hotspot rules
# =============================================================================
HOURLY_COLLECT_TOP_N=50
HOTSPOT_RELEVANCE_THRESHOLD=0.6
HOTSPOT_MAX_AGE_HOURS=72
HOTSPOT_REALTIME_TOP_N=20
HOTSPOT_MIN_RELATED_TOPICS=5

# =============================================================================
# Browser fallback锛堢儹鎼滈噰闆嗘祻瑙堝櫒澶囬摼锛?# =============================================================================
ENABLE_BROWSER_FALLBACK=true
BROWSER_FALLBACK_TIMEOUT_SECONDS=20

# =============================================================================
# Internal API protection锛堢敓浜х幆澧冨繀椤昏缃紱鐣欑┖鍒欎粎寮€鍙戠幆澧冪洿閫氾級
# =============================================================================
INTERNAL_API_KEY=""

# =============================================================================
# Security: JWT锛堢敓浜х幆澧冨繀椤昏缃級
# 鐢熸垚鍛戒护锛歱ython -c "import secrets; print(secrets.token_hex(32))"
# =============================================================================
JWT_SECRET=""
JWT_ALGORITHM="HS256"
JWT_ACCESS_TOKEN_EXPIRE_HOURS=12

# =============================================================================
# Audit logging
# =============================================================================
AUDIT_LOG_ENABLED=true

# =============================================================================
# Runtime safety
# =============================================================================
# 开发/本地：* 允任意 Host；生产建议改为具体域名
TRUSTED_HOSTS="127.0.0.1,localhost,*"
EXPOSE_ERROR_DETAILS=false

# =============================================================================
# Forecast quality gates
FORECAST_TARGET_ACCURACY=0.55
FORECAST_MIN_SAMPLES=10
FORECAST_MIN_COVERAGE=0.03
FORECAST_HISTORY_DAYS=365
QUALITY_GATE_MIN_SCORE=60.0
DAILY_IDEM_REBUILD_AFTER_MINUTES=120

# 模拟实盘与冷启动（05 §7.5a、12 SLO §3.3）
COLD_START_DAILY_SIGNAL_AVG=1.5
SIM_INSTRUCTION_CONFIDENCE_THRESHOLD=0.65
MAX_DRAWDOWN_HALT_THRESHOLD=-0.20
MAX_DRAWDOWN_REDUCE_THRESHOLD=-0.12
DRAWDOWN_HALT_REVIEW_DAYS=3
SIM_SETTLE_TIMEOUT_SECONDS=1800
TDX_INSTALL_DIR=
TDX_HISTORY_DAYS=252
ALERT_WEBHOOK_URL=
ALERT_WEBHOOK_ENABLED=false
ADMIN_ALERT_WEBHOOK_URL=
NOTIFICATION_ENABLED=false

# =============================================================================
# Web 鍚庣锛欳hatGPT锛圥laywright + Chrome锛屼細鍛樿处鍙凤級
# 鐣欑┖鍒欒嚜鍔ㄤ娇鐢ㄥ綋鍓嶇敤鎴?Chrome Default锛屽惎鍔ㄦ椂鎷疯礉鍒颁复鏃剁洰褰?# =============================================================================
CHATGPT_CHROME_USER_DATA=""
CHATGPT_CHROME_PROFILE="Default"
CHATGPT_MAX_CONCURRENCY=5

# =============================================================================
# Web 鍚庣锛欸emini锛圥laywright + Chrome锛屼細鍛樿处鍙凤級
# =============================================================================
GEMINI_CHROME_USER_DATA=""
GEMINI_CHROME_PROFILE="Default"
GEMINI_MAX_CONCURRENCY=5
# 浠ｇ悊锛堝闇€锛岀敤浜庤闂?gemini.google.com锛?GEMINI_PROXY_URL=""

# =============================================================================
# Web backend: Qwen (Playwright + Chrome)
# =============================================================================
QWEN_CHROME_USER_DATA=""
QWEN_CHROME_PROFILE="Default"
QWEN_MAX_CONCURRENCY=5
# Persistent login directory (recommended): reuse login state across restarts.
QWEN_SERVICE_USER_DATA=""
QWEN_FORCE_NO_PROXY=true
QWEN_PROXY_URL=""
QWEN_CDP_URL=""
QWEN_CDP_HIDE_WINDOW=true

# =============================================================================
# Web backend: DeepSeek (Playwright + Chrome, no proxy by default)
# =============================================================================
DEEPSEEK_CHROME_USER_DATA=""
DEEPSEEK_CHROME_PROFILE="Default"
DEEPSEEK_CHROME_MAX_CONCURRENCY=5
# Persistent login directory (recommended): reuse login state across restarts.
DEEPSEEK_CHROME_SERVICE_USER_DATA=""
DEEPSEEK_CHROME_FORCE_NO_PROXY=true

# API proxy for official DeepSeek API (not used in this deployment).
DEEPSEEK_PROXY_URL=""

# =============================================================================
# 鈽?瀹樻柟 API 鎺ュ叆
# 鏈儴缃蹭笉浣跨敤 API Key锛屼粎浣跨敤 ai-api 鍥涗釜 Web API + Codex/Gemini CLI
# 璇﹁ docs/core/AI鎺ュ叆绛栫暐.md
# 浠ヤ笅鍙橀噺鐣欑┖鍗冲彲锛屼笉瑕侀厤缃?# =============================================================================

# DeepSeek 瀹樻柟 API 鈥?鏈儴缃蹭笉浣跨敤锛岀暀绌?DEEPSEEK_API_KEY=""
DEEPSEEK_API_BASE_URL="https://api.deepseek.com/v1"
DEEPSEEK_API_MODEL="deepseek-chat"

# Gemini 瀹樻柟 API 鈥?鏈儴缃蹭笉浣跨敤锛岀暀绌?GEMINI_API_KEY=""
GEMINI_MODEL_TEST="gemini-2.0-flash"
GEMINI_MODEL_PROD="gemini-2.0-flash"

# =============================================================================
# 鈽?鍦烘櫙璺敱鍣ㄩ厤缃紙LLM_BACKEND="router" 鏃剁敓鏁堬級
# =============================================================================
# LLM_BACKEND 鍙€夊€硷細
#   "ollama"  鈥?绾湰鍦帮紙鍘熼粯璁わ紝闄嶇骇鐜?7%锛?#   "router"  鈥?鍦烘櫙鍖栬矾鐢憋紙鎺ㄨ崘锛岄檷绾х巼鐩爣鈮?0%锛?LLM_BACKEND="router"
ROUTER_PRIMARY="deepseek_api"
ROUTER_LONGCTX="gemini_api"
ROUTER_BULK="ollama"
ROUTER_CONFIDENCE_THRESHOLD=0.55
ROUTER_MAX_CONTEXT_TOKENS=8000
